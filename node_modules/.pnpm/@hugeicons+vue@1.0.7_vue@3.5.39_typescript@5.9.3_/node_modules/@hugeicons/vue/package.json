{
  "name": "@hugeicons/vue",
  "version": "1.0.7",
  "description": "Hugeicons Vue Component Library https://hugeicons.com",
  "homepage": "https://hugeicons.com",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "unpkg": "./dist/umd/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE.md",
    "PRO-LICENSE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hugeicons/hugeicons.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/hugeicons/hugeicons/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "author": "Hugeicons",
  "scripts": {
    "build": "pnpm clean && pnpm typecheck && pnpm build:bundles",
    "build:bundles": "rollup -c ./rollup.config.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "publish:beta": "pnpm build && npm publish --tag beta --no-git-checks",
    "publish:prod": "pnpm build && npm publish --no-git-checks"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-sucrase": "^5.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/compiler-sfc": "^3.5.13",
    "rollup": "^3.0.0",
    "rollup-plugin-dts": "^5.3.1",
    "rollup-plugin-vue": "^6.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.7.3",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "vue": "^2.6.0 || ^3.0.0"
  },
  "keywords": [
    "hugeicons",
    "vue",
    "icons",
    "vue-icons",
    "svg-icons",
    "svg",
    "vector-icons",
    "icon-library",
    "typescript"
  ]
}

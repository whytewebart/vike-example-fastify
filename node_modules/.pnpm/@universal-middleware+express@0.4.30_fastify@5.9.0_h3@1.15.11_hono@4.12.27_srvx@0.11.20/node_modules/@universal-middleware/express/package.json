{
  "name": "@universal-middleware/express",
  "version": "0.4.30",
  "type": "module",
  "description": "Express adapter for universal middlewares",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./request": "./dist/request.js"
  },
  "author": "Joël Charles <joel.charles91@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/magne4000/universal-middleware"
  },
  "license": "MIT",
  "dependencies": {
    "@universal-middleware/core": "^0.4.18",
    "@universal-middleware/node": "^0.2.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.6",
    "@types/express4": "npm:@types/express@^4.17.25",
    "@types/node": "^20.19.35",
    "express": "^5.2.1",
    "express4": "npm:express@^4.22.2",
    "helmet": "^8.2.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "@universal-middleware/tests": "0.0.2"
  },
  "sideEffects": false,
  "keywords": [
    "express",
    "universal-middleware",
    "middleware",
    "handlers",
    "server-adapters",
    "express-middleware",
    "universal-server",
    "context-middleware",
    "request-handling"
  ],
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:run-express:node": "tsx tests/entry-express.ts",
    "test:run-express:bun": "bun tests/entry-express.ts",
    "test:run-express:deno": "deno run --unstable-byonm --unstable-sloppy-imports -A tests/entry-express.ts",
    "test:typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
  "type": "module",
  "description": "fastify adapter for universal middlewares",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "author": "Joël Charles <joel.charles91@gmail.com>",
  "repository": "https://github.com/magne4000/universal-middleware",
  "license": "MIT",
  "dependencies": {
    "fastify-raw-body": "^5",
    "@universal-middleware/core": "^0.4.17",
    "@universal-middleware/node": "^0.2.0"
  },
  "devDependencies": {
    "@fastify/helmet": "^13.0.2",
    "@swc/core": "^1.15.33",
    "@types/node": "^20.19.35",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "@universal-middleware/tests": "0.0.2"
  },
  "sideEffects": false,
  "keywords": [
